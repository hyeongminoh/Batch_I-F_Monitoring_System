# Oracle DB 접속 정보
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=your_host
DB_PORT=1521
DB_SID=your_sid

# 멤버쉽 프로그램 ID
MBRSH_PGM_ID=A

# 슬랙 설정
SLACK_CHANNEL=your_slack_channel
SLACK_SCRIPT=/path/to/mon_slack.sh

# 경로 (docker-compose에서는 환경변수로 override됨)
BASE_DATA_DIR=/data
ALARM_DIR=/data/batch_alarms
MODEL_DIR=/data/models
LOG_DIR=/logs
